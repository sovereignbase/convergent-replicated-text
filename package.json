{
  "type": "module",
  "license": "Apache-2.0",
  "name": "@sovereignbase/convergent-replicated-text",
  "version": "0.0.0",
  "description": "Convergent Replicated Text (CR-Text), a delta CRDT for text value state.",
  "keywords": [
    "crdt",
    "text",
    "replicated",
    "convergent",
    "local-first",
    "distributed-systems",
    "delta-sync",
    "gossip",
    "typescript",
    "sovereignbase"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "format": "prettier . --write",
    "build": "tsup && node in-browser-testing-build.js",
    "test": "npm run build && node test/run-coverage.mjs && node test/e2e/run.mjs",
    "bench": "npm run build && node benchmark/bench.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run bench"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@sovereignbase/station-client": "^1.0.0",
    "@types/node": "^25.6.0",
    "c8": "^11.0.0",
    "edge-runtime": "^4.0.1",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@sovereignbase/convergent-replicated-list": "^1.0.7",
    "@sovereignbase/utils": "^1.2.0",
    "uuid": "^13.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sovereignbase/convergent-replicated-text.git"
  },
  "bugs": {
    "url": "https://github.com/sovereignbase/convergent-replicated-text/issues"
  },
  "homepage": "https://github.com/sovereignbase/convergent-replicated-text#readme"
}
